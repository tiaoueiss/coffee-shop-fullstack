<%- include('../partials/header') %>
<h2 class="page-title">Edit Category</h2>

<div class="card" style="max-width:560px;">
  <div class="card-body p-4">
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <form action="/categories/<%= category._id %>?_method=PUT" method="POST">
      <div class="mb-3">
        <label>Name</label>
        <input type="text" name="name" class="form-control" value="<%= category.name %>" required>
      </div>
      <div class="mb-3">
        <label>Description</label>
        <textarea name="description" class="form-control" rows="2"><%= category.description || '' %></textarea>
      </div>
      <div class="mb-3">
        <label>Image filename</label>
        <input type="text" name="image" class="form-control" value="<%= category.image || '' %>" placeholder="e.g. Black Coffee.png">
        <div class="form-text">Place the file in <code>public/images/categories/</code></div>
        <% if (category.image) { %>
          <img src="/images/categories/<%= category.image %>" alt="" class="mt-2 rounded" style="height:80px;object-fit:cover;"
               onerror="this.style.display='none'">
        <% } %>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/categories/<%= category._id %>" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
