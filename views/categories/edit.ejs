<%- include('../partials/header') %>
<h2 class="page-title">Edit Category</h2>

<div class="card">
  <div class="card-body">
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <form action="/categories/<%= category._id %>?_method=PUT" method="POST">
      <div class="mb-3">
        <label>Name</label>
        <input type="text" name="name" class="form-control" value="<%= category.name %>" required>
      </div>
      <div class="mb-3">
        <label>Description</label>
        <textarea name="description" class="form-control" rows="3"><%= category.description || '' %></textarea>
      </div>
      <button type="submit" class="btn btn-coffee me-2">Save</button>
      <a href="/categories/<%= category._id %>" class="btn btn-outline-secondary">Cancel</a>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
