<%- include('../partials/header') %>
<h2 class="page-title">New Category</h2>

<div class="card" style="max-width:560px;">
  <div class="card-body p-4">
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <form action="/categories" method="POST">
      <div class="mb-3">
        <label>Name</label>
        <input type="text" name="name" class="form-control" required>
      </div>
      <div class="mb-3">
        <label>Description</label>
        <textarea name="description" class="form-control" rows="2"></textarea>
      </div>
      <div class="mb-3">
        <label>Image filename <small class="text-muted">(optional — auto-set to Name.png)</small></label>
        <input type="text" name="image" class="form-control" placeholder="e.g. Black Coffee.png">
        <div class="form-text">Place the file in <code>public/images/categories/</code></div>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Create</button>
        <a href="/categories" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
