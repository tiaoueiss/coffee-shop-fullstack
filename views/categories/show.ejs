<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title mb-0"><%= category.name %></h2>
  <% if (user.role === 'admin') { %>
    <a href="/categories/<%= category._id %>/edit" class="btn btn-coffee">Edit</a>
  <% } %>
</div>

<div class="card">
  <div class="card-body">
    <p><%= category.description || 'No description provided.' %></p>
    <a href="/products?category=<%= category._id %>" class="btn btn-outline-secondary">
      <i class="bi bi-bag me-1"></i>View Products in this Category
    </a>
  </div>
</div>

<div class="mt-3">
  <a href="/categories" class="btn btn-outline-secondary">Back to Categories</a>
</div>
<%- include('../partials/footer') %>
