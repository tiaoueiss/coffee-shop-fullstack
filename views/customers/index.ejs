<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title mb-0">Users</h2>
  <% if (user.role === 'admin') { %>
    <a href="/users/new" class="btn btn-primary btn-sm px-3">
      <i class="bi bi-person-plus me-1"></i>Add Staff
    </a>
  <% } %>
</div>

<!-- Role filter pills -->
<div class="d-flex gap-2 flex-wrap mb-4">
  <a href="/users" class="role-pill <%= activeRole === '' ? 'active' : '' %>">All</a>
  <a href="/users?role=customer"  class="role-pill <%= activeRole === 'customer'  ? 'active' : '' %>">Customers</a>
  <a href="/users?role=employee"  class="role-pill <%= activeRole === 'employee'  ? 'active' : '' %>">Employees</a>
  <a href="/users?role=admin"     class="role-pill <%= activeRole === 'admin'     ? 'active' : '' %>">Admins</a>
</div>

<div class="card">
  <div class="card-body p-0">
    <% if (users.length === 0) { %>
      <p class="text-muted p-4 mb-0">No users found.</p>
    <% } else { %>
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>Name</th>
          <th>Username</th>
          <th>Email</th>
          <th>Role</th>
          <th>Loyalty Pts</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr>
          <td class="fw-semibold"><%= u.name %></td>
          <td class="text-muted">@<%= u.username || '—' %></td>
          <td><%= u.email %></td>
          <td>
            <span class="badge rounded-pill
              <%= u.role === 'admin' ? 'bg-dark' : u.role === 'employee' ? 'bg-secondary' : 'bg-success' %>">
              <%= u.role %>
            </span>
          </td>
          <td><%= u.role === 'customer' ? u.loyaltyPoints : '—' %></td>
          <td class="text-end">
            <a href="/users/<%= u._id %>" class="btn btn-sm btn-coffee me-1">View</a>
            <% if (user.role === 'admin') { %>
              <form action="/users/<%= u._id %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('Delete this user?')">
                <button class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
