<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title mb-0">Users</h2>
  <% if (user.role === 'admin') { %>
    <a href="/users/new" class="btn btn-coffee"><i class="bi bi-person-plus me-1"></i>Add Staff</a>
  <% } %>
</div>

<div class="mb-3">
  <a href="/users" class="btn btn-sm btn-outline-secondary me-1">All</a>
  <a href="/users?role=customer" class="btn btn-sm btn-outline-secondary me-1">Customers</a>
  <a href="/users?role=employee" class="btn btn-sm btn-outline-secondary me-1">Employees</a>
  <a href="/users?role=admin" class="btn btn-sm btn-outline-secondary">Admins</a>
</div>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Loyalty Pts</th><th></th></tr></thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr>
          <td><%= u.name %></td>
          <td><%= u.email %></td>
          <td><span class="badge bg-secondary"><%= u.role %></span></td>
          <td><%= u.role === 'customer' ? u.loyaltyPoints : '—' %></td>
          <td>
            <a href="/users/<%= u._id %>" class="btn btn-sm btn-coffee">View</a>
            <% if (user.role === 'admin') { %>
              <form action="/users/<%= u._id %>?_method=DELETE" method="POST" class="d-inline"
                    onsubmit="return confirm('Delete this user?')">
                <button class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>
