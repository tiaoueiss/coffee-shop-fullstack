<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title mb-0"><%= foundUser.name %></h2>
  <div>
    <a href="/users/<%= foundUser._id %>/edit" class="btn btn-coffee me-2">Edit</a>
    <a href="/users/<%= foundUser._id %>/orders" class="btn btn-outline-secondary">Orders</a>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Email</dt>
      <dd class="col-sm-9"><%= foundUser.email %></dd>
      <dt class="col-sm-3">Phone</dt>
      <dd class="col-sm-9"><%= foundUser.phone || '—' %></dd>
      <dt class="col-sm-3">Role</dt>
      <dd class="col-sm-9"><span class="badge bg-secondary"><%= foundUser.role %></span></dd>
      <% if (foundUser.role === 'customer') { %>
      <dt class="col-sm-3">Loyalty Points</dt>
      <dd class="col-sm-9"><i class="bi bi-star-fill text-warning me-1"></i><%= foundUser.loyaltyPoints %></dd>
      <% } %>
      <dt class="col-sm-3">Member Since</dt>
      <dd class="col-sm-9"><%= new Date(foundUser.createdAt).toLocaleDateString() %></dd>
    </dl>
  </div>
</div>

<div class="mt-3">
  <a href="/users" class="btn btn-outline-secondary">Back to Users</a>
</div>
<%- include('../partials/footer') %>
