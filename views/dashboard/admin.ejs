<%- include('../partials/header') %>
<h2 class="page-title"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</h2>

<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card stat-card">
      <div class="card-body">
        <div class="text-muted small">Total Orders</div>
        <div class="fs-2 fw-bold"><%= stats.totalOrders %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card">
      <div class="card-body">
        <div class="text-muted small">Customers</div>
        <div class="fs-2 fw-bold"><%= stats.totalCustomers %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card">
      <div class="card-body">
        <div class="text-muted small">Products</div>
        <div class="fs-2 fw-bold"><%= stats.totalProducts %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card">
      <div class="card-body">
        <div class="text-muted small">Revenue (completed)</div>
        <div class="fs-2 fw-bold">$<%= stats.totalRevenue.toFixed(2) %></div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header"><i class="bi bi-clock-history me-2"></i>Recent Orders</div>
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead><tr><th>Customer</th><th>Items</th><th>Total</th><th>Status</th><th>Date</th><th></th></tr></thead>
      <tbody>
        <% recentOrders.forEach(order => { %>
        <tr>
          <td><%= order.customer?.name || 'N/A' %></td>
          <td><%= order.products.length %></td>
          <td>$<%= order.totalAmount %></td>
          <td><span class="badge badge-<%= order.status %>"><%= order.status %></span></td>
          <td><%= new Date(order.orderDate).toLocaleDateString() %></td>
          <td><a href="/orders/<%= order._id %>" class="btn btn-sm btn-coffee">View</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="mt-3">
  <a href="/orders" class="btn btn-coffee me-2">All Orders</a>
  <a href="/users" class="btn btn-outline-secondary me-2">Manage Users</a>
  <a href="/products/new" class="btn btn-outline-secondary">Add Product</a>
</div>
<%- include('../partials/footer') %>
