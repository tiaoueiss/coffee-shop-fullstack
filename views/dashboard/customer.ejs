<%- include('../partials/header') %>
<h2 class="page-title"><i class="bi bi-person-circle me-2"></i>My Dashboard</h2>

<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card stat-card">
      <div class="card-body">
        <div class="text-muted small"><i class="bi bi-star-fill text-warning me-1"></i>Loyalty Points</div>
        <div class="fs-2 fw-bold"><%= loyaltyPoints %></div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header"><i class="bi bi-bag me-2"></i>Recent Orders</div>
  <div class="card-body p-0">
    <% if (recentOrders.length === 0) { %>
      <p class="text-muted p-3 mb-0">No orders yet. <a href="/orders/new">Place your first order!</a></p>
    <% } else { %>
    <table class="table table-hover mb-0">
      <thead><tr><th>Date</th><th>Items</th><th>Total</th><th>Status</th><th></th></tr></thead>
      <tbody>
        <% recentOrders.forEach(order => { %>
        <tr>
          <td><%= new Date(order.orderDate).toLocaleDateString() %></td>
          <td><%= order.products.length %> item(s)</td>
          <td>$<%= order.totalAmount %></td>
          <td><span class="badge badge-<%= order.status %>"><%= order.status %></span></td>
          <td><a href="/orders/<%= order._id %>" class="btn btn-sm btn-coffee">View</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<div class="mt-3">
  <a href="/products" class="btn btn-coffee me-2">New Order</a>
  <a href="/users/<%= user.id %>" class="btn btn-outline-secondary me-2">My Profile</a>
  <a href="/feedback/new" class="btn btn-outline-secondary">Leave Feedback</a>
</div>
<%- include('../partials/footer') %>
