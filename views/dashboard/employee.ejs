<%- include('../partials/header') %>
<h2 class="page-title"><i class="bi bi-person-badge me-2"></i>Employee Dashboard</h2>

<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card stat-card">
      <div class="card-body">
        <div class="text-muted small">Orders Today</div>
        <div class="fs-2 fw-bold"><%= stats.allTodayOrders %></div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card stat-card">
      <div class="card-body">
        <div class="text-muted small">Pending</div>
        <div class="fs-2 fw-bold text-warning"><%= stats.pendingCount %></div>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header"><i class="bi bi-hourglass-split me-2"></i>Pending Orders</div>
  <div class="card-body p-0">
    <% if (pendingOrders.length === 0) { %>
      <p class="text-muted p-3 mb-0">No pending orders.</p>
    <% } else { %>
    <table class="table table-hover mb-0">
      <thead><tr><th>Customer</th><th>Items</th><th>Total</th><th>Placed</th><th></th></tr></thead>
      <tbody>
        <% pendingOrders.forEach(order => { %>
        <tr>
          <td><%= order.customer?.name || 'N/A' %></td>
          <td>
            <% order.products.forEach(item => { %>
              <small><%= item.product?.name %> x<%= item.quantity %></small><br>
            <% }) %>
          </td>
          <td>$<%= order.totalAmount %></td>
          <td><%= new Date(order.orderDate).toLocaleTimeString() %></td>
          <td>
            <a href="/orders/<%= order._id %>" class="btn btn-sm btn-coffee">View</a>
            <form action="/orders/<%= order._id %>?_method=PUT" method="POST" class="d-inline">
              <input type="hidden" name="status" value="completed">
              <button class="btn btn-sm btn-success">Complete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</div>

<div class="mt-3">
  <a href="/orders/new" class="btn btn-coffee me-2">New Order</a>
  <a href="/orders" class="btn btn-outline-secondary">All Orders</a>
</div>
<%- include('../partials/footer') %>
