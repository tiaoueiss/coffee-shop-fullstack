<%- include('../partials/header') %>
<h2 class="page-title">Update Order Status</h2>

<div class="card">
  <div class="card-body">
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <p><strong>Customer:</strong> <%= order.customer?.name %></p>
    <p><strong>Placed:</strong> <%= new Date(order.orderDate).toLocaleString() %></p>
    <p><strong>Total:</strong> $<%= order.totalAmount %></p>

    <form action="/orders/<%= order._id %>?_method=PUT" method="POST">
      <div class="mb-3">
        <label>Status</label>
        <select name="status" class="form-select">
          <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
          <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Completed</option>
          <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
        </select>
      </div>
      <button type="submit" class="btn btn-coffee me-2">Save</button>
      <a href="/orders/<%= order._id %>" class="btn btn-outline-secondary">Cancel</a>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
