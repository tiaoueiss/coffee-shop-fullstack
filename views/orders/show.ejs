<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title mb-0">Order Details</h2>
  <span class="badge badge-<%= order.status %> fs-6"><%= order.status %></span>
</div>

<div class="row g-4">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header">Items</div>
      <div class="card-body p-0">
        <table class="table mb-0">
          <thead><tr><th>Product</th><th>Qty</th><th>Price</th><th>Subtotal</th></tr></thead>
          <tbody>
            <% order.products.forEach(item => { %>
            <tr>
              <td><%= item.product?.name || 'Deleted product' %></td>
              <td><%= item.quantity %></td>
              <td>$<%= item.product?.price?.toFixed(2) || '—' %></td>
              <td>$<%= item.product ? (item.product.price * item.quantity).toFixed(2) : '—' %></td>
            </tr>
            <% }) %>
          </tbody>
          <tfoot>
            <tr><td colspan="3" class="text-end fw-bold">Total</td><td class="fw-bold">$<%= order.totalAmount %></td></tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Info</div>
      <div class="card-body">
        <p><strong>Customer:</strong> <%= order.customer?.name || '—' %></p>
        <p><strong>Email:</strong> <%= order.customer?.email || '—' %></p>
        <p><strong>Date:</strong> <%= new Date(order.orderDate).toLocaleString() %></p>
        <% if (user.role === 'admin' || user.role === 'employee') { %>
          <form action="/orders/<%= order._id %>?_method=PUT" method="POST">
            <label class="fw-bold">Update Status</label>
            <select name="status" class="form-select mb-2">
              <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
              <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Completed</option>
              <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
            </select>
            <button class="btn btn-coffee w-100">Update</button>
          </form>
        <% } %>
      </div>
    </div>
    <% if (user.role === 'admin') { %>
    <div class="mt-3">
      <form action="/orders/<%= order._id %>?_method=DELETE" method="POST"
            onsubmit="return confirm('Delete this order?')">
        <button class="btn btn-outline-danger w-100">Delete Order</button>
      </form>
    </div>
    <% } %>
  </div>
</div>

<div class="mt-3">
  <a href="/orders" class="btn btn-outline-secondary">Back to Orders</a>
</div>
<%- include('../partials/footer') %>
