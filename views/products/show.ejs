<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="page-title mb-0"><%= product.name %></h2>
  <% if (user && user.role === 'admin') { %>
    <div>
      <a href="/products/<%= product._id %>/edit" class="btn btn-coffee me-2">Edit</a>
      <a href="/products/<%= product._id %>/restock" class="btn btn-outline-success me-2">Restock</a>
      <form action="/products/<%= product._id %>?_method=DELETE" method="POST" class="d-inline"
            onsubmit="return confirm('Delete this product?')">
        <button class="btn btn-outline-danger">Delete</button>
      </form>
    </div>
  <% } %>
</div>

<div class="card">
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Category</dt>
      <dd class="col-sm-9"><%= product.category?.name || '—' %></dd>
      <dt class="col-sm-3">Price</dt>
      <dd class="col-sm-9 fw-bold">$<%= product.price.toFixed(2) %></dd>
      <dt class="col-sm-3">Description</dt>
      <dd class="col-sm-9"><%= product.description || '—' %></dd>
      <dt class="col-sm-3">Inventory</dt>
      <dd class="col-sm-9"><%= product.inventory %> units</dd>
      <dt class="col-sm-3">Available</dt>
      <dd class="col-sm-9">
        <% if (product.isAvailable) { %>
          <span class="text-success"><i class="bi bi-check-circle"></i> Yes</span>
        <% } else { %>
          <span class="text-danger"><i class="bi bi-x-circle"></i> No</span>
        <% } %>
      </dd>
    </dl>
  </div>
</div>

<div class="mt-3">
  <a href="/products" class="btn btn-outline-secondary">Back to Products</a>
</div>
<%- include('../partials/footer') %>
